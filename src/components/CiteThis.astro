---
// Citation box for essay-kind posts: a ready-to-paste citation plus BibTeX.
interface Props {
  title: string;
  date: Date;
  path: string;
}
const { title, date, path } = Astro.props;
const year = date.getFullYear();
const url = new URL(path, Astro.site ?? "https://oranburg.law").href;
const dateLabel = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
const citation = `Seth C. Oranburg, ${title}, oranburg.law (${dateLabel}), ${url}.`;
const key = `oranburg${year}${(title.split(/\s+/)[0] || "essay").toLowerCase().replace(/[^a-z]/g, "")}`;
const bibtex = `@misc{${key},
  author = {Oranburg, Seth C.},
  title  = {${title}},
  year   = {${year}},
  howpublished = {oranburg.law},
  url    = {${url}}
}`;
---

<div class="citebox">
  <h3>Cite this</h3>
  <p>{citation}</p>
  <details>
    <summary style="cursor:pointer;font-size:0.82rem;color:var(--muted);">BibTeX</summary>
    <pre class="bibtex">{bibtex}</pre>
  </details>
</div>
