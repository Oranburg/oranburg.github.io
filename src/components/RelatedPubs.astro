---
// Related-scholarship list for a course page: publications in a cluster,
// optionally narrowed by tag, books and web-excluded entries dropped.
import yaml from "js-yaml";
import fs from "node:fs";
const { cluster, tags = null } = Astro.props;
const schol = yaml.load(fs.readFileSync("src/data/scholarship.yml", "utf8"));
const pubs = (schol.publications ?? []).filter(
  (p) =>
    p.cluster === cluster &&
    p.type !== "book" &&
    !(p.exclude_from ?? []).includes("web") &&
    (!tags || (p.tags ?? []).some((t) => tags.includes(t)))
);
---

<ul class="article-list">
  {pubs.map((pub) => (
    <li class="article-item">
      <div class="article-title">{pub.title}</div>
      <div class="article-journal">
        {pub.journal && `${pub.journal}, `}{pub.status === "forthcoming" ? "forthcoming " : ""}{pub.year}
        {pub.links?.ssrn && <> | <a href={pub.links.ssrn} target="_blank" rel="noopener">SSRN</a></>}
        {pub.links?.published && <> | <a href={pub.links.published} target="_blank" rel="noopener">Full Text</a></>}
      </div>
    </li>
  ))}
</ul>
