---
import "../styles/og-tokens.css";
import "../styles/og-components.css";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";

const SITE_TITLE = "Seth C. Oranburg";
const SITE_DESCRIPTION =
  "Law professor and scholar researching how technological disruption destabilizes moral norms and social trust, and how legal design can restore integrity to markets and institutions.";

interface Props {
  title?: string;
  description?: string;
  tagline?: string;
  heroSubtitle?: string;
  home?: boolean;
  image?: string;
  trail?: { label: string; href: string }[];
  current?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  tagline,
  heroSubtitle,
  home = false,
  image = "/images/SCO - Purple Suit.jpg",
  trail = [{ label: "Home", href: "https://oranburg.law" }],
  current,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#FFFFFF" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0A3255" media="(prefers-color-scheme: dark)" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" type="image/png" href="/assets/icons/o-dot-favicon.png" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400&family=Oswald:wght@500..700&family=Roboto:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/site.css" />
    {home && <link rel="stylesheet" href="/assets/css/home.css" />}
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem("theme");
          if (theme === "light" || theme === "dark") {
            document.documentElement.setAttribute("data-theme", theme);
          } else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches) {
            document.documentElement.setAttribute("data-theme", "light");
          } else {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <!-- Structured data for AI/search discovery -->
    <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Seth C. Oranburg",
    "url": "https://oranburg.law",
    "image": "https://oranburg.law/images/SCO - Purple Suit.jpg",
    "jobTitle": "Ordinary Professor of Law and Director of the Law and Entrepreneurship Program",
    "description": "Law professor and scholar researching how technological disruption destabilizes moral norms and social trust, and how legal design can restore integrity to markets and institutions.",
    "knowsAbout": [
      "Contract Law",
      "Business Associations",
      "Corporate Law",
      "Securities Regulation",
      "Trade Secrets",
      "Fintech",
      "Digital Assets",
      "Cryptocurrency",
      "Decentralized Autonomous Organizations",
      "Stablecoin Regulation",
      "CLARITY Act",
      "University Governance",
      "Legal Design",
      "Institutional Trust"
    ],
    "sameAs": [
      "https://www.youtube.com/@BizLaw",
      "https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=2256355",
      "https://bizlawbreakdown.podbean.com",
      "https://oranburg.law/K/",
      "https://oranburg.law/BA/",
      "https://oranburg.law/BA/RUP",
      "https://oranburg.law/safety-machine/",
      "https://oranburg.law/demos/exclusive-inclusion/",
      "https://actag.bio"
    ],
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "University of Chicago Law School" },
      { "@type": "CollegeOrUniversity", "name": "University of Florida" }
    ],
    "worksFor": {
      "@type": "CollegeOrUniversity",
      "name": "The Catholic University of America, Columbus School of Law"
    },
    "award": [
      "University Excellence in Teaching Award (2024)",
      "Center for Teaching Excellence Inclusive Teaching Award (2021)",
      "Presidential Scholarship Award (2019)"
    ],
    "mainEntityOfPage": "https://oranburg.law"
  }
  </script>
  </head>
  <body>
    <a href="#main-content" style="position:absolute;left:-999px;top:auto;width:1px;height:1px;overflow:hidden;" onfocus="this.style.cssText='position:fixed;top:0;left:0;width:auto;height:auto;padding:1rem;background:var(--accent-red);color:#fff;z-index:999;font-size:1rem;text-decoration:none;'" onblur="this.style.cssText='position:absolute;left:-999px;top:auto;width:1px;height:1px;overflow:hidden;'">Skip to content</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="site-title" href="/">{SITE_TITLE}</a>
        <p class="site-tagline">{tagline ?? SITE_DESCRIPTION}</p>
        {heroSubtitle && <p class="site-hero-subtitle">{heroSubtitle}</p>}
      </div>
    </header>

    <nav class="site-nav" aria-label="Main navigation">
      <button class="nav-toggle" onclick="var nav=this.closest('.site-nav');nav.classList.toggle('open');this.setAttribute('aria-expanded',nav.classList.contains('open'))" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/insights/">Insights</a></li>
        <li><a href="/courses/">Courses</a></li>
        <li><a href="/scholarship/">Scholarship</a></li>
        <li><a href="/press/">Press</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li>
          <button class="theme-toggle" onclick="toggleTheme()" aria-label="Switch to light mode">
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </li>
      </ul>
    </nav>

    {home && (
      <nav class="home-local-nav" aria-label="On-page sections">
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#research">Research</a></li>
          <li><a href="#commentary">Commentary</a></li>
          <li><a href="#teaching">Teaching</a></li>
        </ul>
      </nav>
    )}

    <main class="site-content" id="main-content">
      <Breadcrumb trail={[...trail, ...(current ?? title ? [{ label: current ?? title }] : [])]} />
      <slot />
    </main>

    <Footer
      links={[
        { label: "Home", href: "https://oranburg.law" },
        { label: "Insights", href: "/insights/" },
        { label: "Courses", href: "/courses/" },
        { label: "Scholarship", href: "/scholarship/" },
        { label: "Press", href: "/press/" },
        { label: "Contact", href: "/contact/" },
      ]}
      note="© 2026 Seth C. Oranburg. All rights reserved."
    />

    <script is:inline src="/assets/js/site.js"></script>
  </body>
</html>
