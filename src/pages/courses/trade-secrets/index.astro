---
import yaml from "js-yaml";
import fs from "node:fs";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PlaylistEmbed from "../../../components/PlaylistEmbed.astro";
import BookCardById from "../../../components/BookCardById.astro";
import RelatedPubs from "../../../components/RelatedPubs.astro";
const schol = yaml.load(fs.readFileSync("src/data/scholarship.yml", "utf8"));
const pub = (id) => (schol.publications ?? []).find((p) => p.id === id);
---

<BaseLayout title="Trade Secret Law" current="Trade Secret Law">
  <p class="back-to-courses"><a href="/courses/">&larr; Back to Courses</a></p>

  <div class="hub-intro">
    <h1>Trade Secret Law</h1>
    <p class="literary">Protection of confidential business information, misappropriation claims, workforce mobility, and the strategic tension between secrecy and disclosure.</p>
  </div>

  <h2>Casebook</h2>
  <p>The course uses Oranburg's casebook on trade secret law.</p>
  {pub("protecting-trade-secrets") && (
    <>
      <div class="book-grid">
        <a href={pub("protecting-trade-secrets").links?.published} target="_blank" class="book-card">
          <div class="book-title">{pub("protecting-trade-secrets").title}</div>
          <div class="book-publisher">{pub("protecting-trade-secrets").journal} ({pub("protecting-trade-secrets").status === "forthcoming" ? "forthcoming " : ""}{pub("protecting-trade-secrets").year})</div>
          <span class="book-link">{pub("protecting-trade-secrets").status === "forthcoming" ? "Pre-order" : "Buy"} now &rarr;</span>
        </a>
      </div>
      <p>Companion materials and resources are available on the <a href="https://cap-press.com/books/isbn/9781531034375/Protecting-Trade-Secrets" target="_blank">Protecting Trade Secrets (Carolina Academic Press)</a>.</p>
    </>
  )}

  <h2>Podcast: Organized</h2>
  <p>Audio lectures on trade secret law fundamentals, covering the UTSA, Defend Trade Secrets Act, and practical strategies for protecting confidential information.</p>
  <details class="embed">
    <summary>Listen to the Trade Secrets Podcast Series</summary>
    <div class="podcast-embed">
      <iframe style="border: none; min-width: min(100%, 430px);" title="Organized: The Business Law Breakdown — Trade Secrets" src="https://www.podbean.com/player-v2/?i=p6w7w-1260bda-pbblog-playlist&share=1&download=1&rtl=0&fonts=Trebuchet%20MS&skin=3267a3&font-color=auto&logo_link=episode_page&order=serial&limit=30&filter=season&season=12&ss=4fd5d0446d6f9ac6ae4a92fa2eee7c9f&btn-skin=666666&size=315" width="100%" height="315" loading="lazy" allowfullscreen="allowfullscreen"></iframe>
    </div>
  </details>

  <h2>Video Lectures</h2>
  <p>Supplemental video content on trade secret law.</p>
  <PlaylistEmbed id="PL2OBGU7rnJY6lKd5u3MhESxRiLWmVnd3d" />

  <h2>Related Scholarship</h2>
  <p>Published articles on trade secret misappropriation, valuation, and IP remedies.</p>
  <RelatedPubs cluster="ip" />
</BaseLayout>
