---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// URL parity with Jekyll: /insights/YYYY/MM/DD/slug/ from the post filename.
export async function getStaticPaths() {
  const posts = (await getCollection("insights")).sort(
    (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
  );
  return posts.map((post, i) => {
    const m = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+?)(?:\.md)?$/);
    if (!m) throw new Error(`Post filename without a date prefix: ${post.id}`);
    return {
      params: { path: `${m[1]}/${m[2]}/${m[3]}/${m[4]}` },
      props: { post, prev: posts[i - 1] ?? null, next: posts[i + 1] ?? null },
    };
  });
}

function postUrl(p) {
  const m = p.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+?)(?:\.md)?$/);
  return `/insights/${m[1]}/${m[2]}/${m[3]}/${m[4]}/`;
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const words = post.body ? post.body.split(/\s+/).length : 0;
const minutes = Math.max(1, Math.ceil(words / 220));
const dateLabel = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  trail={[
    { label: "Home", href: "https://oranburg.law" },
    { label: "Insights", href: "/insights/" },
  ]}
  current={post.data.title}
>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">
        <time datetime={post.data.date.toISOString()}>{dateLabel}</time>
        &middot; <span class="post-readtime">{minutes} min read</span>
        {post.data.tags.length > 0 && (
          <>
            &middot; {post.data.tags.map((tag) => <span class="post-tag">{tag} </span>)}
          </>
        )}
      </p>
    </header>

    <div class="post-content">
      <Content />
    </div>

    <nav class="post-nav" aria-label="Post navigation">
      {prev && <a class="prev" href={postUrl(prev)}>&larr; {prev.data.title}</a>}
      {next && <a class="next" href={postUrl(next)}>{next.data.title} &rarr;</a>}
    </nav>
  </article>
</BaseLayout>
