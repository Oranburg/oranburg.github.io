---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScholarMeta from "../../components/ScholarMeta.astro";
import CiteThis from "../../components/CiteThis.astro";

// URL parity with Jekyll: /insights/YYYY/MM/DD/slug/ from the post filename.
export async function getStaticPaths() {
  const posts = (await getCollection("insights")).sort(
    (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
  );
  return posts.map((post, i) => {
    const m = post.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+?)(?:\.md)?$/);
    if (!m) throw new Error(`Post filename without a date prefix: ${post.id}`);
    return {
      params: { path: `${m[1]}/${m[2]}/${m[3]}/${m[4]}` },
      props: { post, prev: posts[i - 1] ?? null, next: posts[i + 1] ?? null },
    };
  });
}

function postUrl(p) {
  const m = p.id.match(/^(\d{4})-(\d{2})-(\d{2})-(.+?)(?:\.md)?$/);
  return `/insights/${m[1]}/${m[2]}/${m[3]}/${m[4]}/`;
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const words = post.body ? post.body.split(/\s+/).length : 0;
const minutes = Math.max(1, Math.ceil(words / 220));
const dateLabel = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
// Essays and guides carry the scholarly apparatus (Scholar meta, citation
// box, margin sidenotes built from footnotes), ported from the aotv template.
const scholarly = post.data.kind === "essay" || post.data.kind === "guide";
const path = Astro.url.pathname;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  trail={[
    { label: "Home", href: "https://oranburg.law" },
    { label: "Insights", href: "/insights/" },
  ]}
  current={post.data.title}
>
  {scholarly && (
    <Fragment slot="head">
      <link rel="stylesheet" href="/assets/css/essay-apparatus.css" />
      <ScholarMeta title={post.data.title} date={post.data.date} abstract={post.data.excerpt} path={path} />
    </Fragment>
  )}
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-meta">
        <time datetime={post.data.date.toISOString()}>{dateLabel}</time>
        &middot; <span class="post-readtime">{minutes} min read</span>
        {post.data.tags.length > 0 && (
          <>
            &middot; {post.data.tags.map((tag) => <span class="post-tag">{tag} </span>)}
          </>
        )}
      </p>
    </header>

    <div class="post-content">
      <Content />
    </div>

    {scholarly && (
      <script is:inline>
        // Build margin sidenotes from GFM footnotes (from the aotv template).
        // Without JS the endnote section stays visible, so nothing is lost.
        (function () {
          var essay = document.querySelector(".post-content");
          if (!essay) return;
          var refs = essay.querySelectorAll("a[data-footnote-ref]");
          refs.forEach(function (ref) {
            var href = ref.getAttribute("href");
            if (!href) return;
            var li = essay.querySelector(href);
            if (!li) return;
            var clone = li.cloneNode(true);
            clone.querySelectorAll("a[data-footnote-backref]").forEach(function (b) { b.remove(); });
            var aside = document.createElement("aside");
            aside.className = "sidenote";
            aside.innerHTML = '<sup class="sidenote-num">' + (ref.textContent || "") + "</sup> " + clone.innerHTML.trim();
            var sup = ref.closest("sup") || ref;
            var block = sup.parentElement;
            while (block && block.parentElement !== essay && !/^(P|LI|BLOCKQUOTE|H2|H3|H4)$/.test(block.tagName)) {
              block = block.parentElement;
            }
            var anchorEl = block && block.parentElement === essay ? block : sup;
            while (anchorEl.nextElementSibling && anchorEl.nextElementSibling.classList.contains("sidenote")) {
              anchorEl = anchorEl.nextElementSibling;
            }
            anchorEl.insertAdjacentElement("afterend", aside);
          });
          document.documentElement.classList.add("sidenotes-ready");
        })();
      </script>
    )}

    {scholarly && <CiteThis title={post.data.title} date={post.data.date} path={path} />}

    <nav class="post-nav" aria-label="Post navigation">
      {prev && <a class="prev" href={postUrl(prev)}>&larr; {prev.data.title}</a>}
      {next && <a class="next" href={postUrl(next)}>{next.data.title} &rarr;</a>}
    </nav>
  </article>
</BaseLayout>
