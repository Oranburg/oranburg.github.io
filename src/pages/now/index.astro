---
import fs from "node:fs";
import BaseLayout from "../../layouts/BaseLayout.astro";

// The /now page's source of truth stays at now/index.html, which the lawj
// now pipeline (audit / refresh / trim) writes. This page reads it at build
// time, so the pipeline needs no retargeting.
const raw = fs.readFileSync("now/index.html", "utf8");
const m = raw.match(/^---\n[\s\S]*?\n---\n([\s\S]*)$/);
const buildMonth = new Date().toLocaleDateString("en-US", { month: "long", year: "numeric" });
const body = (m ? m[1] : raw).replace('{{ site.time | date: "%B %Y" }}', buildMonth);
if (/{[{%]/.test(body)) {
  throw new Error("now/index.html grew Liquid this page cannot render; update src/pages/now/index.astro");
}
---

<BaseLayout
  title="Now"
  tagline="What I'm working on this month"
  description="A snapshot of Seth C. Oranburg's current projects, teaching, and writing, updated periodically."
  current="Now"
>
  <Fragment set:html={body} />
</BaseLayout>
